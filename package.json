{
  "name": "@yevgetman/sov",
  "version": "0.1.0",
  "description": "Sovereign AI agent runtime — Claude-Code-style harness with Hermes-pattern learning layer.",
  "type": "module",
  "module": "src/main.ts",
  "bin": {
    "sov": "./src/main.ts"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yevgetman/sovereign-ai-harness.git"
  },
  "homepage": "https://github.com/yevgetman/sovereign-ai-harness#readme",
  "bugs": {
    "url": "https://github.com/yevgetman/sovereign-ai-harness/issues"
  },
  "license": "UNLICENSED",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "claude",
    "harness",
    "llm",
    "mcp"
  ],
  "scripts": {
    "chat": "bun src/main.ts",
    "eval:website": "bun src/evals/websiteBuildEval.ts",
    "test": "bun test",
    "test:semantic": "bun tests/semantic/run.ts",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@commander-js/extra-typings": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.0"
  }
}
