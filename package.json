{
  "name": "@yevgetman/sov",
  "version": "0.4.1",
  "description": "Sovereign AI agent runtime — Claude-Code-style harness with Hermes-pattern learning layer.",
  "private": true,
  "type": "module",
  "module": "src/main.ts",
  "bin": {
    "sov": "./src/main.ts",
    "harness": "./src/main.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yevgetman/sovereign-ai-harness.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "chat": "bun src/main.ts",
    "release": "bun run scripts/release.ts",
    "eval:website": "bun src/evals/websiteBuildEval.ts",
    "test": "bun test",
    "test:semantic": "bun tests/semantic/run.ts",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "tui:build": "bun run scripts/build-tui.ts",
    "postinstall": "bun run scripts/build-tui.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@commander-js/extra-typings": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "cron-parser": "^4.9.0",
    "hono": "^4.12.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
