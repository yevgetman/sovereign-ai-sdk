{
  "name": "@yevgetman/sov",
  "version": "0.6.66",
  "description": "Sovereign AI agent runtime \u2014 Claude-Code-style harness with Hermes-pattern learning layer.",
  "private": true,
  "workspaces": [
    "packages/sdk",
    "packages/protocol"
  ],
  "type": "module",
  "module": "src/main.ts",
  "exports": {
    ".": "./src/main.ts"
  },
  "bin": {
    "sov": "./src/main.ts",
    "harness": "./src/main.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yevgetman/sovereign-ai-sdk.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "chat": "bun src/main.ts",
    "release": "bun run scripts/release.ts",
    "release:build": "bun run scripts/release-build-target.ts",
    "release:upload": "bun run scripts/release-upload.ts",
    "eval:website": "bun src/evals/websiteBuildEval.ts",
    "eval:learning": "bun run src/learning-layer/eval/runner.ts",
    "eval:synthesis-audit": "bun run src/learning-layer/eval/synthesisAudit.ts",
    "boundary": "bun --bun depcruise packages/sdk/src packages/protocol/src --config .dependency-cruiser.cjs",
    "test": "bun test --timeout 20000",
    "test:semantic": "bun tests/semantic/run.ts",
    "lint": "biome check src tests packages && bun run boundary",
    "format": "biome format --write src tests packages",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:protocol && bun run build:sdk",
    "build:protocol": "cd packages/protocol && bun run build",
    "build:sdk": "cd packages/sdk && bun run build",
    "canary": "bun scripts/canary/run-consumer-canary.ts",
    "tui:build": "bun run scripts/build-tui.ts",
    "visual": "bun run scripts/visual.ts",
    "postinstall": "bun run scripts/build-tui.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@commander-js/extra-typings": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@yevgetman/decorum": "file:../decorum",
    "@yevgetman/sov-protocol": "workspace:*",
    "@yevgetman/sov-sdk": "workspace:*",
    "chalk": "^5.3.0",
    "cron-parser": "^4.9.0",
    "hono": "^4.12.0",
    "ink": "^5.0.1",
    "picomatch": "^4.0.4",
    "react": "^18.3.1",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18.3.0",
    "dependency-cruiser": "^18.0.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
